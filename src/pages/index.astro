---
import "../styles/global.css";
import yritys from "../data/yritys.json";

// Sloganin fiksutus: Jaetaan pääotsikkoon ja korostettuun tekstiin
const sloganParts = yritys.slogan
  ? yritys.slogan.split("–")
  : ["Laadukasta palvelua", "Ammattitaidolla"];
const headlineMain = sloganParts[0].trim();
const headlineAccent =
  sloganParts.length > 1 ? sloganParts.slice(1).join("–").trim() : "";
---

<html lang="fi" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    
    {/* --- PERUS SEO --- */}
    <title>{yritys.nimi ? `${yritys.nimi} | ${yritys.paikkakunta}` : "Uusi Yritys"}</title>
    <meta name="description" content={yritys.slogan || "Palvelemme ammattitaidolla"} />
    <meta name="theme-color" content="#1e3a8a" /> {/* Tailwind blue-900 mobiiliselaimen yläpalkkiin */}

    {/* --- OPEN GRAPH (Facebook, WhatsApp, LinkedIn) --- */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={yritys.nimi ? `${yritys.nimi} | ${yritys.paikkakunta}` : "Uusi Yritys"} />
    <meta property="og:description" content={yritys.slogan || "Palvelemme ammattitaidolla"} />
    {yritys.heroKuva && <meta property="og:image" content={yritys.heroKuva} />}

    {/* --- TWITTER / X CARD --- */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={yritys.nimi || "Uusi Yritys"} />
    <meta name="twitter:description" content={yritys.slogan || "Palvelemme ammattitaidolla"} />
    {yritys.heroKuva && <meta name="twitter:image" content={yritys.heroKuva} />}

    {/* --- FONTTI-IKONIT --- */}
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons|Material+Icons+Round" rel="stylesheet" />
  </head>
  <body
    class="min-h-screen bg-gray-50 text-gray-900 antialiased font-sans flex flex-col"
  >
    {/* --- HEADER (Lasi-efekti) --- */}
    <header
      class="sticky top-0 z-50 border-b border-gray-200/60 bg-white/80 backdrop-blur-xl"
    >
      <div
        class="mx-auto grid max-w-7xl grid-cols-[minmax(0,1fr)_auto] items-center gap-4 px-5 py-4 md:grid-cols-3 md:px-8"
      >
        <a href="#top" class="flex min-w-0 items-center gap-3">
          <span
            class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-blue-900 text-white shadow-md"
          >
            <span class="material-icons-round text-[22px]">construction</span>
          </span>
          <span
            class="truncate text-xl font-black tracking-tight text-gray-900 uppercase"
          >
            {yritys.nimi || "YRITYS"}
          </span>
        </a>

        <nav class="hidden items-center justify-center gap-8 md:flex">
          {
            yritys.palvelut && yritys.palvelut.length > 0 && (
              <a
                href="#palvelut"
                class="text-sm font-bold text-gray-500 transition-colors hover:text-blue-900 uppercase tracking-wide"
              >
                Palvelut
              </a>
            )
          }
          {
            yritys.edut && yritys.edut.length > 0 && (
              <a
                href="#edut"
                class="text-sm font-bold text-gray-500 transition-colors hover:text-blue-900 uppercase tracking-wide"
              >
                Edut
              </a>
            )
          }
          {
            yritys.arvostelut && yritys.arvostelut.length > 0 && (
              <a
                href="#arvostelut"
                class="text-sm font-bold text-gray-500 transition-colors hover:text-blue-900 uppercase tracking-wide"
              >
                Kokemuksia
              </a>
            )
          }
        </nav>

        <div class="flex justify-end">
          <a
            href="#yhteys"
            class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-6 py-2.5 text-sm font-bold text-white shadow-md transition-all hover:-translate-y-0.5 hover:bg-blue-700 hover:shadow-lg"
          >
            <span class="hidden sm:inline">Ota yhteyttä</span>
            <span class="sm:hidden">Yhteys</span>
            <span class="material-icons-round text-[18px]">arrow_forward</span>
          </a>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      {/* --- HERO --- */}
      {/* --- HERO --- */}
      {/* Poistettiin overflow-hidden tästä: */}
      <section
        id="top"
        class="relative isolate flex min-h-[85vh] items-center pb-32"
      >
        {/* Ja lisättiin overflow-hidden tähän taustakääreeseen: */}
        <div class="absolute inset-0 -z-10 bg-blue-950 overflow-hidden">
          {
            yritys.heroKuva && (
              <img
                src={yritys.heroKuva}
                alt={yritys.nimi}
                class="h-full w-full object-cover opacity-50"
                fetchpriority="high"
                decoding="async"
              />
            )
          }
          <div
            class="absolute inset-0 bg-gradient-to-br from-blue-900/90 via-blue-900/75 to-transparent"
          >
          </div>
        </div>

        {/* ... loppuosa Hero-sektiosta pysyy täysin samana ... */}

        <div class="mx-auto w-full max-w-7xl px-5 pt-28 pb-20 md:px-8 md:pt-36">
          <div class="max-w-3xl">
            <div
              data-reveal
              class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-white/90 backdrop-blur-md opacity-0 translate-y-8 transition-all duration-700"
            >
              <span
                class="h-2 w-2 rounded-full bg-orange-500 shadow-[0_0_8px_rgba(249,115,22,0.8)]"
              ></span>
              {yritys.paikkakunta || "Paikallinen"} · {
                yritys.toimiala || "Palvelu"
              }
            </div>

            <h1
              data-reveal
              data-delay="100"
              class="text-5xl font-extrabold leading-[1.05] text-white sm:text-6xl md:text-7xl lg:text-[80px] opacity-0 translate-y-8 transition-all duration-700 tracking-tight"
            >
              {headlineMain}
              <span class="mt-3 block text-orange-500">{headlineAccent}</span>
            </h1>

            <p
              data-reveal
              data-delay="200"
              class="mt-8 max-w-xl text-lg text-white/80 md:text-xl font-light opacity-0 translate-y-8 transition-all duration-700"
            >
              Ammattitaitoa, läpinäkyvyyttä ja pysyvää jälkeä – {
                yritys.paikkakunta || "alueesi"
              } luotetuin kumppani.
            </p>

            <div
              data-reveal
              data-delay="300"
              class="mt-10 flex flex-wrap items-center gap-4 opacity-0 translate-y-8 transition-all duration-700"
            >
              <a
                href="#yhteys"
                class="group inline-flex items-center gap-3 rounded-full bg-orange-500 px-8 py-4 text-base font-bold text-white shadow-xl transition-all hover:-translate-y-1 hover:bg-orange-400"
              >
                Pyydä ilmainen tarjous
                <span
                  class="material-icons-round text-[20px] transition-transform group-hover:translate-x-1"
                  >arrow_forward</span
                >
              </a>
              {
                yritys.puhelin && (
                  <a
                    href={`tel:${yritys.puhelin.replace(/\s/g, "")}`}
                    class="inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/5 px-6 py-4 text-base font-bold text-white backdrop-blur-md transition-colors hover:bg-white/20"
                  >
                    <span class="material-icons-round text-[20px]">phone</span>
                    {yritys.puhelin}
                  </a>
                )
              }
            </div>
          </div>
        </div>

        {/* TILASTOT PÄÄLLEKKÄIN HERO-KUVAN KANSSA (WOW-efekti) */}
        {
          yritys.vartit && yritys.vartit.length > 0 && (
            <div class="absolute inset-x-0 bottom-0 z-10 translate-y-1/2 px-5 md:px-8">
              <div
                data-reveal
                data-delay="400"
                class="mx-auto grid max-w-5xl grid-cols-1 overflow-hidden rounded-3xl bg-white shadow-2xl sm:grid-cols-3 border border-gray-100 opacity-0 translate-y-12 transition-all duration-1000"
              >
                {yritys.vartit.map((v, i) => (
                  <div
                    class={`flex flex-col items-center gap-1 px-6 py-10 text-center ${i > 0 ? "border-t border-gray-100 sm:border-l sm:border-t-0" : ""}`}
                  >
                    <div class="text-4xl md:text-5xl font-black text-blue-900 tracking-tighter">
                      {v.luku}
                    </div>
                    <div class="text-sm font-bold uppercase tracking-wider text-gray-500 mt-2">
                      {v.teksti}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </section>

      {/* Tilaa päällekkäisille tilastoille */}
      <div class="h-40 md:h-48"></div>

      {/* --- PALVELUT --- */}
      {
        yritys.palvelut && yritys.palvelut.length > 0 && (
          <section id="palvelut" class="px-5 py-20 md:px-8 max-w-7xl mx-auto">
            <div class="mx-auto mb-16 max-w-2xl text-center">
              <div
                data-reveal
                class="mb-4 text-xs font-black uppercase tracking-[0.2em] text-orange-500 opacity-0 translate-y-8 transition-all duration-700"
              >
                Palvelumme
              </div>
              <h2
                data-reveal
                data-delay="100"
                class="text-4xl font-extrabold leading-tight text-gray-900 md:text-5xl opacity-0 translate-y-8 transition-all duration-700"
              >
                Kaikki ratkaisut yhdeltä luukulta
              </h2>
            </div>

            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {yritys.palvelut.map((p, i) => (
                <article
                  data-reveal
                  data-delay={String(i * 100)}
                  class="group relative overflow-hidden rounded-3xl border border-gray-100 bg-white p-10 shadow-sm transition-all duration-300 hover:-translate-y-2 hover:shadow-xl opacity-0 translate-y-12"
                >
                  <div class="mb-8 grid h-16 w-16 place-items-center rounded-2xl bg-blue-50 text-blue-600 transition-colors group-hover:bg-blue-600 group-hover:text-white">
                    <span class="material-icons-round text-[32px]">
                      {p.ikoni || "build"}
                    </span>
                  </div>
                  <h3 class="text-2xl font-bold text-gray-900 mb-4">
                    {p.nimi}
                  </h3>
                  <p class="text-gray-600 leading-relaxed">{p.kuvaus}</p>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {/* --- EDUT --- */}
      {
        yritys.edut && yritys.edut.length > 0 && (
          <section id="edut" class="bg-gray-100 px-5 py-24 md:px-8 md:py-32">
            <div class="mx-auto grid max-w-7xl gap-16 lg:grid-cols-[1fr_1.2fr] lg:items-center">
              <div>
                <div
                  data-reveal
                  class="mb-4 text-xs font-black uppercase tracking-[0.2em] text-orange-500 opacity-0 translate-y-8 transition-all duration-700"
                >
                  Miksi me
                </div>
                <h2
                  data-reveal
                  data-delay="100"
                  class="text-4xl font-extrabold leading-tight text-gray-900 md:text-5xl opacity-0 translate-y-8 transition-all duration-700"
                >
                  Rakennettu kestämään ja luottamaan.
                </h2>
                <p
                  data-reveal
                  data-delay="200"
                  class="mt-6 text-xl text-gray-600 opacity-0 translate-y-8 transition-all duration-700"
                >
                  Meiltä saat avaimet käteen -palvelun ilman yllätyksiä tai
                  piilokuluja.
                </p>
              </div>

              <div class="grid gap-6 sm:grid-cols-2">
                {yritys.edut.map((e, i) => (
                  <div
                    data-reveal
                    data-delay={String(i * 100)}
                    class="rounded-3xl border border-gray-100 bg-white p-8 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md opacity-0 translate-y-12"
                  >
                    <div class="mb-6 grid h-14 w-14 place-items-center rounded-2xl bg-orange-100 text-orange-600">
                      <span class="material-icons-round text-[28px]">
                        {e.ikoni || "star"}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">
                      {e.otsikko}
                    </h3>
                    <p class="text-gray-600">{e.teksti}</p>
                  </div>
                ))}
              </div>
            </div>
          </section>
        )
      }

      {/* --- ARVOSTELUT --- */}
      {
        yritys.arvostelut && yritys.arvostelut.length > 0 && (
          <section id="arvostelut" class="px-5 py-24 md:px-8 max-w-7xl mx-auto">
            <div class="mx-auto mb-16 max-w-2xl text-center">
              <div
                data-reveal
                class="mb-4 text-xs font-black uppercase tracking-[0.2em] text-orange-500 opacity-0 translate-y-8 transition-all duration-700"
              >
                Asiakkaamme sanovat
              </div>
              <h2
                data-reveal
                data-delay="100"
                class="text-4xl font-extrabold leading-tight text-gray-900 md:text-5xl opacity-0 translate-y-8 transition-all duration-700"
              >
                Lopputulos, joka kestää aikaa.
              </h2>
            </div>

            <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 justify-center">
              {yritys.arvostelut.map((a, i) => (
                <article
                  data-reveal
                  data-delay={String(i * 100)}
                  class="relative overflow-hidden rounded-3xl border border-gray-100 bg-white p-10 shadow-lg opacity-0 translate-y-12 transition-all duration-700"
                >
                  <span
                    aria-hidden
                    class="material-icons-round pointer-events-none absolute -right-4 -top-8 !text-[160px] text-gray-50 select-none z-0"
                  >
                    format_quote
                  </span>
                  <div class="relative z-10">
                    <div class="mb-6 flex items-center gap-1 text-orange-400">
                      {[0, 1, 2, 3, 4].map(() => (
                        <span class="material-icons-round text-[20px]">
                          star
                        </span>
                      ))}
                    </div>
                    <p class="text-lg leading-relaxed text-gray-700 font-medium italic">
                      "{a.teksti}"
                    </p>
                    <div class="mt-8 flex items-center gap-4 border-t border-gray-100 pt-6">
                      <div class="grid h-12 w-12 place-items-center rounded-full bg-blue-900 text-lg font-bold text-white shadow-md">
                        {a.kirjain}
                      </div>
                      <div class="text-base font-bold text-gray-900">
                        {a.nimi}
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {/* --- CTA --- */}
      <section
        id="yhteys"
        class="relative isolate overflow-hidden bg-blue-900 px-5 py-24 text-white md:px-8 md:py-32"
      >
        <div
          class="absolute inset-0 -z-10 opacity-40 bg-[radial-gradient(circle_at_20%_20%,rgba(249,115,22,0.3)_0%,transparent_40%),radial-gradient(circle_at_80%_80%,rgba(37,99,235,0.5)_0%,transparent_50%)]"
        >
        </div>
        <div class="mx-auto max-w-4xl text-center">
          <div
            data-reveal
            class="mb-4 text-xs font-black uppercase tracking-[0.2em] text-orange-400 opacity-0 translate-y-8 transition-all duration-700"
          >
            Aloitetaan
          </div>
          <h2
            data-reveal
            data-delay="100"
            class="text-5xl font-black leading-[1.1] md:text-6xl lg:text-7xl opacity-0 translate-y-8 transition-all duration-700 tracking-tight"
          >
            Valmis aloittamaan <span class="block text-orange-500"
              >projektisi?</span
            >
          </h2>
          <p
            data-reveal
            data-delay="200"
            class="mx-auto mt-8 max-w-2xl text-xl text-blue-100 font-light opacity-0 translate-y-8 transition-all duration-700"
          >
            Soita tai laita viestiä – vastaamme nopeasti ja annamme
            asiantuntijan arvion kohteeseesi.
          </p>

          <div
            data-reveal
            data-delay="300"
            class="mt-12 flex flex-wrap items-center justify-center gap-6 opacity-0 translate-y-8 transition-all duration-700"
          >
            {
              yritys.puhelin && (
                <a
                  href={`tel:${yritys.puhelin.replace(/\s/g, "")}`}
                  class="group inline-flex items-center gap-3 rounded-full bg-orange-500 px-10 py-5 text-xl font-bold text-white shadow-2xl transition-all hover:-translate-y-1 hover:bg-orange-400"
                >
                  <span class="material-icons-round text-[24px]">
                    phone_in_talk
                  </span>
                  {yritys.puhelin}
                </a>
              )
            }
            {
              yritys.sahkoposti && (
                <a
                  href={`mailto:${yritys.sahkoposti}`}
                  class="inline-flex items-center gap-3 rounded-full border-2 border-white/20 bg-white/5 px-10 py-5 text-xl font-bold text-white backdrop-blur-md transition-all hover:bg-white/10 hover:border-white/40"
                >
                  <span class="material-icons-round text-[24px]">mail</span>
                  {yritys.sahkoposti}
                </a>
              )
            }
          </div>
        </div>
      </section>
    </main>

    {/* --- FOOTER --- */}
    <footer class="bg-gray-950 px-5 py-16 md:px-8 text-gray-400">
      <div class="mx-auto grid max-w-7xl gap-10 md:grid-cols-3">
        <div>
          <div class="flex items-center gap-3 text-white mb-4">
            <span
              class="grid h-10 w-10 place-items-center rounded-xl bg-blue-900 shadow-md"
            >
              <span class="material-icons-round text-[20px]">construction</span>
            </span>
            <span class="text-xl font-black uppercase tracking-tight"
              >{yritys.nimi}</span
            >
          </div>
          <p class="text-sm leading-relaxed">{yritys.slogan}</p>
        </div>

        <div>
          <div class="font-bold text-white uppercase tracking-wider mb-4">
            Yhteystiedot
          </div>
          <ul class="space-y-3 text-sm">
            <li class="flex items-center gap-2">
              <span class="material-icons-round text-[16px] text-gray-500"
                >location_on</span
              >
              {yritys.osoite}
            </li>
            <li class="flex items-center gap-2">
              <span class="material-icons-round text-[16px] text-gray-500"
                >phone</span
              >
              {yritys.puhelin}
            </li>
            <li class="flex items-center gap-2">
              <span class="material-icons-round text-[16px] text-gray-500"
                >email</span
              >
              {yritys.sahkoposti}
            </li>
          </ul>
        </div>

        <div class="md:text-right flex flex-col justify-between">
          <div class="text-sm">
            © {new Date().getFullYear()}
            {yritys.nimi}.<br /> Kaikki oikeudet pidätetään.
          </div>
          <div class="mt-4 text-xs text-gray-600">
            Toteutus: Sivustotehtaasi
          </div>
        </div>
      </div>
    </footer>

    {/* --- VANILLA JS ANIMAATIOT (Korvaa Reactin useRevealin) --- */}
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;
                // Luetaan viive data-delay -attribuutista (oletus 0ms)
                const delay = parseInt(el.getAttribute("data-delay") || "0");

                setTimeout(() => {
                  el.classList.remove(
                    "opacity-0",
                    "translate-y-8",
                    "translate-y-12",
                  );
                }, delay);

                observer.unobserve(el);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );

        document.querySelectorAll("[data-reveal]").forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
