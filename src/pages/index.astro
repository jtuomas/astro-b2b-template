---
import '../styles/global.css';
import yritys from '../data/yritys.json';
---

<html lang="fi" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={yritys.slogan || "Paikallista ja luotettavaa palvelua"} />
    <title>{yritys.nimi ? `${yritys.nimi} | ${yritys.paikkakunta}` : "Uusi Yritys"}</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased text-gray-800 bg-gray-50 flex flex-col min-h-screen">

    <header class="bg-white shadow-md p-4 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <div class="text-2xl font-black text-blue-900 tracking-tighter uppercase relative z-10">
          {yritys.nimi || "MALLIYRITYS"}
        </div>
        
        {/* --- DESKTOP NAVIGOINTI (Piilotettu mobiilissa) --- */}
        <nav class="hidden md:flex space-x-8 font-semibold text-gray-600">
          {yritys.palvelut && yritys.palvelut.length > 0 && (
            <a href="#palvelut" class="hover:text-blue-600 transition-colors">Palvelut</a>
          )}
          {yritys.edut && yritys.edut.length > 0 && (
            <a href="#edut" class="hover:text-blue-600 transition-colors">Edut</a>
          )}
          {yritys.arvostelut && yritys.arvostelut.length > 0 && (
            <a href="#arvostelut" class="hover:text-blue-600 transition-colors">Kokemuksia</a>
          )}
        </nav>

        <a href="#yhteys" class="bg-blue-600 text-white px-5 py-2.5 rounded-md font-bold hover:bg-blue-700 transition duration-300 shadow-sm hover:shadow-md relative z-10">
          Ota yhteyttä
        </a>
      </div>
    </header>

    <main class="flex-grow overflow-hidden">
      {/* --- HERO --- */}
      <section class="relative bg-gray-900 text-white h-[80vh] min-h-[600px] flex items-center justify-center">
        {yritys.heroKuva && (
          <img 
            src={yritys.heroKuva} 
            alt={`Kuvituskuva yritykselle ${yritys.nimi}`} 
            class="absolute inset-0 w-full h-full object-cover opacity-30 z-0"
            fetchpriority="high"
            decoding="async"
          />
        )}
        <div class="relative z-10 text-center max-w-4xl px-4 reveal-element opacity-0 translate-y-12 transition-all duration-1000 ease-out">
          <h1 class="text-5xl md:text-7xl font-extrabold mb-6 tracking-tight leading-tight drop-shadow-lg">
            {yritys.slogan ? yritys.slogan.split(' – ')[0] : 'Laadukasta palvelua'} <br/> 
            <span class="text-orange-500">{yritys.paikkakunta || 'Lähialueella'}</span>
          </h1>
          <p class="text-xl md:text-2xl mb-10 text-gray-200 max-w-2xl mx-auto font-light drop-shadow-md">
            {yritys.slogan || 'Ota yhteyttä, kun tarvitset ammattilaista kohteeseesi!'}
          </p>
          <a href="#yhteys" class="inline-block bg-orange-500 hover:bg-orange-600 text-white text-lg font-bold py-4 px-10 rounded-full transition duration-300 shadow-[0_0_20px_rgba(249,115,22,0.4)] hover:shadow-[0_0_30px_rgba(249,115,22,0.6)] hover:-translate-y-1">
            Pyydä ilmainen arviokäynti
          </a>
        </div>
      </section>

      {/* --- TILASTOT / VARTIT --- */}
      {yritys.vartit && yritys.vartit.length > 0 && (
        <section class="bg-blue-600 text-white py-12 px-4 relative z-20 shadow-xl">
          <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-8 md:gap-16 text-center">
            {yritys.vartit.map((vartti, index) => (
              <div class="px-4 reveal-element opacity-0 translate-y-12 transition-all duration-700 ease-out" style={`transition-delay: ${index * 150}ms`}>
                <div class="text-4xl md:text-5xl font-black mb-2 tracking-tight">{vartti.luku}</div>
                <div class="text-blue-100 font-medium uppercase tracking-wider text-sm">{vartti.teksti}</div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* --- PALVELUT --- */}
      {yritys.palvelut && yritys.palvelut.length > 0 && (
        <section id="palvelut" class="py-24 px-4 max-w-6xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-extrabold text-center mb-16 text-gray-900 reveal-element opacity-0 translate-y-12 transition-all duration-700 ease-out">Palvelumme</h2>
          {/* Korjattu asettelu: Käytetään flexboxia ja keskitystä gridin sijaan */}
          <div class="flex flex-wrap justify-center gap-8">
            {yritys.palvelut.map((palvelu, index) => (
              <div class="w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] max-w-md bg-white p-8 rounded-3xl shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col items-start reveal-element opacity-0 translate-y-12 ease-out hover:-translate-y-2 group" style={`transition-delay: ${index * 150}ms`}>
                <div class="bg-blue-50 p-4 rounded-2xl mb-6 text-blue-600 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
                  <span class="material-icons text-3xl">{palvelu.ikoni || 'check_circle'}</span>
                </div>
                <h3 class="text-xl font-bold mb-3 text-gray-800">{palvelu.nimi}</h3>
                <p class="text-gray-600 leading-relaxed">{palvelu.kuvaus}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* --- EDUT --- */}
      {yritys.edut && yritys.edut.length > 0 && (
        <section id="edut" class="py-24 px-4 bg-gray-100">
          <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-extrabold text-center mb-16 text-gray-900 reveal-element opacity-0 translate-y-12 transition-all duration-700 ease-out">Miksi valita meidät?</h2>
            <div class="flex flex-wrap justify-center gap-12">
              {yritys.edut.map((etu, index) => (
                <div class="w-full md:w-[calc(50%-1.5rem)] lg:w-[calc(33.333%-2rem)] max-w-md flex items-start space-x-5 reveal-element opacity-0 translate-y-12 transition-all duration-700 ease-out" style={`transition-delay: ${index * 150}ms`}>
                  <div class="bg-orange-100 p-3 rounded-full flex-shrink-0">
                    <span class="material-icons text-orange-500 text-3xl">{etu.ikoni || 'star'}</span>
                  </div>
                  <div>
                    <h3 class="text-xl font-bold mb-2 text-gray-800">{etu.otsikko}</h3>
                    <p class="text-gray-600 leading-relaxed">{etu.teksti}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* --- ARVOSTELUT --- */}
      {yritys.arvostelut && yritys.arvostelut.length > 0 && (
        <section id="arvostelut" class="py-24 px-4 max-w-5xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-extrabold text-center mb-16 text-gray-900 reveal-element opacity-0 translate-y-12 transition-all duration-700 ease-out">Asiakkaiden kokemuksia</h2>
          <div class="flex flex-wrap justify-center gap-8">
            {yritys.arvostelut.map((arvostelu, index) => (
              <div class="w-full md:w-[calc(50%-1rem)] max-w-lg bg-white p-10 rounded-3xl shadow-lg border border-gray-50 relative reveal-element opacity-0 translate-y-12 transition-all duration-700 ease-out" style={`transition-delay: ${index * 150}ms`}>
                <span class="material-icons text-blue-50 text-7xl absolute top-4 right-4 z-0">format_quote</span>
                <p class="text-gray-700 text-lg italic mb-8 relative z-10 leading-relaxed">"{arvostelu.teksti}"</p>
                <div class="flex items-center space-x-4 relative z-10">
                  <div class="w-14 h-14 bg-gradient-to-br from-blue-600 to-blue-800 text-white rounded-full flex items-center justify-center font-bold text-2xl shadow-md">
                    {arvostelu.kirjain}
                  </div>
                  <div class="font-bold text-gray-900 text-lg">{arvostelu.nimi}</div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* --- NÄYTTÄVÄ CALL TO ACTION (CTA) --- */}
      <section id="yhteys" class="bg-blue-600 py-24 px-4 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-black opacity-10"></div>
        <div class="max-w-4xl mx-auto relative z-10 reveal-element opacity-0 translate-y-12 transition-all duration-700 ease-out">
          <h2 class="text-4xl md:text-6xl font-black mb-6 text-white tracking-tight drop-shadow-md">Ota yhteyttä heti!</h2>
          <p class="text-xl md:text-2xl mb-12 text-blue-100 font-light">
            Vastaamme nopeasti. Kysy rohkeasti arviota kohteeseesi.
          </p>
          
          <div class="flex flex-col md:flex-row justify-center items-center gap-6">
            {yritys.puhelin && (
              <a href={`tel:${yritys.puhelin.replace(/\s+/g, '')}`} class="w-full md:w-auto bg-white text-blue-900 text-2xl font-bold py-5 px-10 rounded-full shadow-2xl hover:scale-105 transition-transform flex items-center justify-center gap-3 hover:bg-gray-50">
                <span class="material-icons text-orange-500">phone_in_talk</span> 
                {yritys.puhelin}
              </a>
            )}
            {yritys.sahkoposti && (
              <a href={`mailto:${yritys.sahkoposti}`} class="w-full md:w-auto bg-blue-800 text-white border-2 border-blue-400 text-xl font-bold py-5 px-10 rounded-full hover:bg-blue-700 transition-colors flex items-center justify-center gap-3">
                <span class="material-icons text-blue-300">mail</span> 
                Sähköpostilla
              </a>
            )}
          </div>
        </div>
      </section>

    </main>

    {/* --- FOOTER --- */}
    <footer class="bg-gray-900 text-gray-300 py-12 px-4 mt-auto">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center text-center md:text-left gap-6">
        <div>
          <h3 class="text-2xl font-black text-white tracking-tighter uppercase mb-2">
            {yritys.nimi || "YRITYS"}
          </h3>
          <p class="text-gray-500 text-sm">{yritys.osoite}</p>
        </div>
        <div class="text-sm text-gray-500">
          <p>&copy; {new Date().getFullYear()} {yritys.nimi}. Kaikki oikeudet pidätetään.</p>
        </div>
      </div>
    </footer>

    {/* --- WOW-EFEKTI: SCROLL ANIMAATIOT --- */}
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const observerOptions = {
          root: null,
          rootMargin: "0px",
          threshold: 0.15 // Aktivoituu kun 15% elementistä on näkyvissä
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.remove('opacity-0', 'translate-y-12');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal-element').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>